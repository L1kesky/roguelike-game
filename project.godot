; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

"ï»¿config_version"=5

[application]

config/name="RoguelikeGame"
config/description="A roguelike dungeon crawler created with Godot 4"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6")

[display]

window/size/viewport_width=1400
window/size/viewport_height=900

[limit]

fps=60

[performance]

limits/time/fps_limit=60
physics/common/physics_fps=60
application/run_when_out_of_focus=true

[rendering]

renderer/rendering_method="gl_compatibility"
